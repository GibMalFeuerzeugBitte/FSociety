    "merge.incomingHeaderBackground": "#3C5B3FAA",
    "statusBar.background": "#13070B",
    "statusBar.foreground": "#F4DDE4",
    "statusBar.border": "#241015",
    "statusBar.debuggingBackground": "#1F0B11",
    "statusBar.debuggingForeground": "#F8C7D3",
    "statusBar.noFolderBackground": "#10060A",
    "statusBarItem.hoverBackground": "#271017",
    "panel.background": "#040507",
    "panel.border": "#1A1215",
    "panelTitle.activeBorder": "#8E2438",
    "panelTitle.activeForeground": "#EAF4FF",
    "panelTitle.inactiveForeground": "#989898",
    "tab.activeBackground": "#000000",
    "tab.activeForeground": "#EAF4FF",
    "tab.inactiveBackground": "#050608",
    "tab.inactiveForeground": "#8998A6",
    "tab.border": "#1A1215",
    "tab.activeBorder": "#8E2438",
    "tab.unfocusedActiveBorder": "#4A1A25",
    "editorGroupHeader.tabsBackground": "#020304",
    "editorGroup.border": "#1A1215",
    "scrollbarSlider.background": "#5A5A5A55",
    "scrollbarSlider.hoverBackground": "#6B6B6B77",
    "scrollbarSlider.activeBackground": "#7A7A7A88",
    "minimap.selectionHighlight": "#6A6A6A66",
    "minimap.findMatchHighlight": "#B7365188",
    "minimap.errorHighlight": "#E06C75AA",
    "terminal.background": "#000000",
    "terminal.foreground": "#EAF4FF",
    "terminalCursor.foreground": "#FF5F7E",
    "terminal.selectionBackground": "#0D3A5980",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiRed": "#E06C75",
    "terminal.ansiGreen": "#98C379",
    "terminal.ansiYellow": "#D19A66",
    "terminal.ansiBlue": "#5EA8FF",
    "terminal.ansiMagenta": "#FF62A8",
    "terminal.ansiCyan": "#5EA8FF",
    "terminal.ansiWhite": "#E4E4E4",
    "terminal.ansiBrightBlack": "#5C6370",
    "terminal.ansiBrightRed": "#F07D86",
    "terminal.ansiBrightGreen": "#A9D38A",
    "terminal.ansiBrightYellow": "#E5C07B",
    "terminal.ansiBrightBlue": "#8FC2FF",
    "terminal.ansiBrightMagenta": "#FF8BC0",
    "terminal.ansiBrightCyan": "#8FC2FF",
    "terminal.ansiBrightWhite": "#F3F3F3"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7B5A63",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#6BFFB3"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#FF2F68"
      }
    },
    {
      "name": "Number and Constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#FF9A7A"
      }
    },
    {
      "name": "Function and Method",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#FF3B3B"
      }
    },
    {
      "name": "Type and Class",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#FF7A45"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#FF4E78"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#FFB3C2"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF1744"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#FF7A45",
    "class": "#FF7A45",
    "enum": "#FF7A45",
    "interface": "#FF7A45",
    "struct": "#FF7A45",
    "typeParameter": "#FF7A45",
    "type": "#FF7A45",
    "parameter": "#FFC2CF",
    "variable": "#FF4E78",
    "property": "#FFB3C2",
    "enumMember": "#FF9A7A",
    "decorator": "#FF3B3B",
    "function": "#FF3B3B",
    "method": "#FF3B3B",
    "keyword": "#FF2F68",
    "comment": {
      "foreground": "#7B5A63",
      "fontStyle": "italic"
    },
    "string": "#6BFFB3",
    "number": "#FF9A7A"
  }
}

    "editor.findMatchBackground": "#B7365144",
    "editor.findMatchBorder": "#FF5F7E",
    "editor.findMatchHighlightBackground": "#B7365126",
    "editor.findMatchHighlightBorder": "#8E243866",
    "editor.findRangeHighlightBackground": "#4B4B4B77",
    "editor.hoverHighlightBackground": "#12223377",
    "editorIndentGuide.background1": "#18232C",
    "editorIndentGuide.activeBackground1": "#2A3D4D",
    "editorGutter.background": "#000000",
    "editorGutter.modifiedBackground": "#61AFEF",
    "editorGutter.addedBackground": "#98C379",
    "editorGutter.deletedBackground": "#E06C75",
    "editorWhitespace.foreground": "#1D2A35",
    "editorBracketMatch.background": "#3A1B2466",
    "editorBracketMatch.border": "#B73651",
    "editorWidget.background": "#05090F",
    "editorWidget.border": "#2A171D",
    "editorWidget.resizeBorder": "#8E2438",
    "editorSuggestWidget.background": "#05090F",
    "editorSuggestWidget.border": "#2A171D",
    "editorSuggestWidget.foreground": "#EAF4FF",
    "editorSuggestWidget.highlightForeground": "#FF6C8A",
    "editorSuggestWidget.selectedBackground": "#0E1822",
    "editorHoverWidget.background": "#05090F",
    "editorHoverWidget.border": "#2A171D",
    "editorOverviewRuler.findMatchForeground": "#B73651AA",
    "editorOverviewRuler.selectionHighlightForeground": "#6B7180AA",
    "peekView.border": "#8E2438",
    "peekViewEditor.background": "#1D1D1D",
    "peekViewEditor.matchHighlightBackground": "#B7365138",
    "peekViewResult.background": "#181818",
    "peekViewResult.selectionBackground": "#272727",
    "peekViewTitle.background": "#1B1B1B",
